<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="10dp"
    android:paddingEnd="10dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:background="@color/primary_color">

    <View
        android:id="@+id/bus_line_color"
        android:layout_width="4dp"
        android:layout_height="match_parent"
        android:background="@color/white"
        tools:background="@color/purple_700"/>

    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_bus"
        app:tint="@color/white"
        android:layout_marginStart="10dp"/>

    <TextView
        android:id="@+id/bus_destination_code"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/russo_one_regular"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:layout_marginStart="5dp"
        tools:text="1721-10"/>

    <TextView
        android:id="@+id/destination"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/varta_variable_font_weight"
        android:layout_marginStart="10dp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:textSize="16sp"
        tools:text="Jardim Brasil - Metrô Carandiru"/>


</LinearLayout>